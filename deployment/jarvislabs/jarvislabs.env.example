# Copy to deployment/jarvislabs/jarvislabs.env and adjust as needed.

PUBLIC_PORT=6006
PLATFORM_PORT=6006
GENERAL_LLM_PORT=8004
MEDICAL_LLM_PORT=8002
MEDISCAN_PORT=8001
OCR_PORT=8003

POSTGRES_PORT=15432
POSTGRES_USER=medai
POSTGRES_DB=medai
REDIS_PORT=16379

DATA_ROOT=/home/medai-stack
MODELS_DIR=/home/medai-models
HF_HOME=/home/medai-models

GENERAL_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
GENERAL_LLM_CUDA_DEVICES=0
GENERAL_LLM_DTYPE=float16
GENERAL_LLM_GPU_MEMORY_UTILIZATION=0.90
GENERAL_LLM_MAX_MODEL_LEN=8192

MEDICAL_LLM_CUDA_DEVICES=1,2,3,4
MEDICAL_LLM_MODEL_CONFIG=medical_llm/config/model_config.jarvislabs_a6000x8.yaml
MEDICAL_LLM_MAX_RESIDENT_MODELS=1
MEDICAL_LLM_AUTO_UNLOAD_AFTER_REQUEST=true
MEDICAL_LLM_SEQUENTIAL_HEAVY_MODELS=true
MEDICAL_LLM_MAX_CONCURRENT_REQUESTS=1
MEDICAL_LLM_MAX_QUEUE_DEPTH=2
MEDICAL_LLM_VECTOR_STORE=faiss
MEDICAL_LLM_INGEST_BUILTIN=true

MEDISCAN_CUDA_DEVICES=5,6,7
MEDISCAN_MAX_RESIDENT_MODELS=2
MEDISCAN_AUTO_UNLOAD_AFTER_INFERENCE=true
MEDISCAN_SEQUENTIAL_HEAVY_MODELS=true

MEDISCAN_PREFER_REMOTE_API=false
SARVAM_API_KEY=
PUBMED_API_KEY=
SEARXNG_URL=
ENABLE_OPENRAG=false
OPENRAG_URL=http://127.0.0.1:8006
ENABLE_CONTEXT_GRAPH=false
CONTEXT_GRAPH_URL=http://127.0.0.1:8007
ENABLE_CONTEXT1_AGENT=false
CONTEXT1_URL=http://127.0.0.1:8008

ENVIRONMENT=staging
WORKERS=1
