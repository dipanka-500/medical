# MediScan AI v7.0 — .gitignore

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
.venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Logs & audit trails
logs/
*.log

# Data (large files — use Git LFS or external storage)
data/
*.nii
*.nii.gz
*.dcm
*.svs
*.ndpi

# Model weights (download at runtime)
/models/
*.bin
*.safetensors
*.pt
*.pth
*.onnx

# Environment & secrets
.env
.env.*
*.key

# OS
.DS_Store
Thumbs.db

# Docker
docker-compose.override.yml
