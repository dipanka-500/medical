# ═══════════════════════════════════════════════════════════════════
#  MedAI Platform — Environment Variables
#  Copy to .env and fill in all required values before starting.
#
#  First-time setup:
#    1. cp .env.example .env
#    2. Fill in required values below
#    3. pip install huggingface_hub
#    4. python scripts/download_models.py --tier core
#    5. docker compose up --build
# ═══════════════════════════════════════════════════════════════════

# ── Environment ───────────────────────────────────────────────────
ENVIRONMENT=development                    # development | staging | production

# ── Database (REQUIRED) ──────────────────────────────────────────
POSTGRES_USER=medai
POSTGRES_PASSWORD=                         # REQUIRED — set a strong password
POSTGRES_DB=medai
POSTGRES_PORT=5432

# ── Auth Secrets (REQUIRED for staging/production) ───────────────
# Generate with: openssl rand -hex 64
JWT_SECRET_KEY=CHANGE-ME-IN-PRODUCTION-use-openssl-rand-hex-64
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE-ME-32-byte-key-for-aes256

# ── Redis / Valkey (REQUIRED) ──────────────────────────────────────
REDIS_PASSWORD=                              # REQUIRED — set a strong password
REDIS_PORT=6379

# ── Service Ports ─────────────────────────────────────────────────
PLATFORM_PORT=8000
VLM_PORT=8001
LLM_PORT=8002
OCR_PORT=8003
GENERAL_LLM_PORT=8004
FRONTEND_PORT=3000

# ── Local Models (ALL open-source, NO external API calls) ────────
# Pre-download before first run:
#   python scripts/download_models.py --tier core          (~25GB)
#   python scripts/download_models.py --tier medical       (~65GB)
#   python scripts/download_models.py --tier full          (~300GB+)
MODELS_DIR=./models                        # Host directory for pre-downloaded models

# General LLM model (conversational backbone for ALL queries)
# Default: Qwen2.5-7B-Instruct (Apache 2.0, excellent quality)
# Smaller: Qwen/Qwen2.5-3B-Instruct (if low on RAM)
GENERAL_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
GENERAL_LLM_MAX_CONCURRENT=2
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# ── Voice Stack (optional open-source speech) ─────────────────────
# Turn this on to install the optional faster-whisper + Coqui XTTS stack
# into the platform image. CPU install is supported by default; GPU users
# can override the Dockerfile or image build as needed for their CUDA stack.
PLATFORM_INSTALL_VOICE=false
VOICE_ASR_PROVIDER=disabled                 # disabled | faster_whisper
VOICE_ASR_MODEL=large-v3
VOICE_ASR_DEVICE=auto                       # auto | cpu | cuda
VOICE_ASR_COMPUTE_TYPE=int8
VOICE_TTS_PROVIDER=disabled                 # disabled | coqui
VOICE_TTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2
VOICE_TTS_DEVICE=auto                       # auto | cpu | cuda
VOICE_TTS_LANGUAGE=en

# HuggingFace token (for gated models like Llama, MedGemma)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=

# ── AI Engine API Keys ────────────────────────────────────────────
MEDICAL_LLM_API_KEY=                       # optional: protect LLM engine endpoint
MEDISCAN_API_KEY=                          # optional: protect MediScan VLM endpoint
PUBMED_API_KEY=                            # optional: PubMed search integration
SARVAM_API_KEY=                            # optional: Sarvam Vision OCR backend (only external API)

# ── HIPAA Compliance ────────────────────────────────────────────
# Persistent salt for deterministic PHI anonymization. REQUIRED in production.
# Generate with: openssl rand -hex 16
MEDISCAN_PHI_SALT=

# ── Granite Vision 4.0 3B (document extraction sidecar) ─────────
GRANITE_ENABLED=true
GRANITE_PORT=8005
GRANITE_CUDA_DEVICES=0
GRANITE_USE_VLLM=true
GRANITE_TIMEOUT_SECONDS=120
GRANITE_MAX_TOKENS=4096

# ── OpenRAG Service (agentic RAG + hybrid search) ───────────────
OPENRAG_PORT=8006
OPENRAG_OPENSEARCH_ENABLED=true
OPENRAG_RERANKER_ENABLED=true
OPENRAG_CHUNK_SIZE=512
OPENRAG_CHUNK_OVERLAP=64

# ── Neo4j / Context Graph (patient longitudinal memory) ─────────
NEO4J_USER=neo4j
NEO4J_PASSWORD=                            # REQUIRED — set a strong password
NEO4J_DATABASE=neo4j
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
CONTEXT_GRAPH_PORT=8007
CONTEXT_GRAPH_ENCRYPT_PHI=true

# ── Chroma Context-1 Agent (multi-hop retrieval — stub harness) ──
CONTEXT1_PORT=8008
CONTEXT1_MAX_TURNS=4
CONTEXT1_TOKEN_BUDGET=8000

# ── OpenSearch (full-text search for hybrid retrieval) ───────────
OPENSEARCH_PORT=9200

# ── GPU Configuration ────────────────────────────────────────────
VLM_CUDA_DEVICES=0                         # GPU device ID for VLM engine
LLM_CUDA_DEVICES=0                         # GPU device ID for LLM engine
GENERAL_LLM_CUDA_DEVICES=0                # GPU device ID for general LLM

# ── Email (optional — for verification / 2FA) ────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── SSL/TLS (optional — for direct termination) ──────────────────
SSL_CERTFILE=
SSL_KEYFILE=

# ── Frontend ──────────────────────────────────────────────────────
# In Docker, use /api/v1 (nginx proxies to platform service)
# For local dev, use http://localhost:8000/api/v1
VITE_API_URL=/api/v1

# ── Build Metadata ────────────────────────────────────────────────
BUILD_DATE=
VCS_REF=
